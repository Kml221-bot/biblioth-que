{
  "name": "bibliotech-pro",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
  "predeploy": "npm run build",
  "deploy": "gh-pages -d dist/public",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:nest\" \"npm run dev:client\"",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev:nest\" \"npm run dev:client\"",
    "build": "vite build --configLoader runner && tsc -p tsconfig.server.json",
    "start": "node -e \"process.env.NODE_ENV='production'; import('./dist/index.js')\"",
    "preview": "vite preview --host --configLoader runner",
    "check": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "analyze": "cross-env ANALYZE=true vite build --configLoader runner",
    "types:supabase": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > client/src/types/database.gen.ts",
    "format": "prettier --write .",
    "dev:server": "tsx watch server/index.ts",
    "dev:nest": "tsx watch --tsconfig tsconfig.nest-check.json src/main.ts",
    "build:nest": "node scripts/prepare-nest-build.cjs && tsc -p tsconfig.nest-build.json",
    "start:nest": "node scripts/start-nest.cjs",
    "dev:client": "vite --host --configLoader runner",
    "dev:client-only": "vite --host --configLoader runner",
    "setup": "docker compose up -d && npm install && npm run prisma:generate && npm run seed",
    "prisma:generate": "npx prisma generate",
    "prisma:introspect": "npx prisma db pull --schema prisma/introspect.prisma",
    "prisma:push": "npx prisma db push",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "seed": "npx prisma db seed",
    "start:dev": "npm run dev:nest",
    "test:e2e": "jest --config test/jest-e2e.config.ts --runInBand --forceExit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
