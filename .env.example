# ═══════════════════════════════════════════════════════════
# BiblioTech — Variables d'Environnement
# ═══════════════════════════════════════════════════════════
# Setup rapide :
#   1. cp .env.example .env
#   2. docker compose up -d
#   3. npm install
#   4. npx prisma migrate dev
#   5. npx prisma db seed
#   6. npm run start:dev
# ═══════════════════════════════════════════════════════════

# OpenRouter (BibliAI)
OPENROUTER_API_KEY=sk-or-v1-xxx

# OpenWeather — Météo Dakar sur le dashboard (gratuit, 60 req/min)
# Créer un compte sur https://openweathermap.org/api → clé gratuite "Current Weather Data"
OPENWEATHER_API_KEY=

# Serveur Express (chat AI + reader proxy)
PORT=3001
# Serveur NestJS (API principale)
NEST_PORT=3002
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=debug

# NestJS API / Prisma
# ─ Option A : PostgreSQL local via Docker (npm run docker:up)
#   DATABASE_URL=postgresql://bibliotech:bibliotech_dev_2024@localhost:5432/bibliotech?schema=public
#   DIRECT_URL=postgresql://bibliotech:bibliotech_dev_2024@localhost:5432/bibliotech?schema=public
#
# ─ Option B : Supabase PostgreSQL (recommandé — Settings > Database > Connection string)
#   Transaction pooler (port 6543) :
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#   Direct connection (port 5432) :
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
JWT_SECRET=replace-with-at-least-32-characters-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Alternative recommandee en cloud (Railway/Upstash) :
# REDIS_URL=rediss://default:password@host:6379
REDIS_TLS=false

# Supabase — Frontend (exposées via VITE_)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_ANON_KEY=eyJxxx
VITE_ADMIN_EMAILS=admin@ton-domaine.com

# Lecteur et telechargement de livres externes
# Ajoute ici les domaines qui peuvent etre lus/telecharges via le proxy BiblioTech.
READER_PROXY_ALLOWED_HOSTS=openlibrary.org,archive.org,gutenberg.org,www.gutenberg.org,mangadex.org,www.mangadex.org
READER_PROXY_MAX_BYTES=52428800

# ── WhatsApp via Meta Cloud API (officiel, GRATUIT 1000 conv/mois) ──────────
# Créer une app sur developers.facebook.com → WhatsApp → Getting Started
META_WHATSAPP_PHONE_ID=        # Ex: 123456789012345
META_WHATSAPP_ACCESS_TOKEN=    # Token permanent de ta Meta App

# ── Africa's Talking SMS (fallback WhatsApp + SMS direct) ────────────────────
# Créer un compte sur africastalking.com → Dashboard → Settings → API Key
# Opérateurs couverts : Orange Sénégal, Free Mobile, Expresso
AT_USERNAME=sandbox            # 'sandbox' pour les tests, ton username en prod
AT_API_KEY=                    # API Key Africa's Talking

# ── Twilio (ancien provider — gardé pour compatibilité, peut être vide) ──────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_MESSAGING_SERVICE_SID=

# SMS urgents AfricasTalking
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=
AT_USERNAME=
AT_API_KEY=

# Lecteur offline — secret AES-256 pour chiffrer les tokens de téléchargement
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OFFLINE_TOKEN_SECRET=replace-with-64-hex-chars

# Push PWA Web Push / VAPID
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@bibliotech.sn

# Jobs automatiques emprunts/amendes
DISABLE_BORROW_CRON=false
BORROW_CRON_TIMEZONE=Africa/Dakar
WAVE_AUTO_DEBIT_API_URL=
WAVE_AUTO_DEBIT_API_KEY=

# Naboopay — Paiements Wave / Orange Money / Free Money
NABOOPAY_MERCHANT_ID=
NABOOPAY_API_KEY=
NABOOPAY_WEBHOOK_SECRET=
NABOOPAY_ENV=sandbox

# Email transactionnel optionnel
RESEND_API_KEY=
RESEND_FROM=BiblioTech <notifications@bibliotech.sn>
EMAIL_FROM=BiblioTech <notifications@bibliotech.sn>

# Supabase — Serveur (privées, jamais exposées côté client)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# Sentry — monitoring erreurs (optionnel, laisser vide pour désactiver)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Supabase CLI — pour générer les types TypeScript
# Usage : pnpm types:supabase
SUPABASE_PROJECT_ID=xxx
